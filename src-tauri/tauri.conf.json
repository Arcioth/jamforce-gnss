{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "jamforce-gnss",
  "version": "0.1.0",
  "identifier": "com.jamforce.gnss",
  "build": {
    "frontendDist": "../templates",
    "devUrl": "http://127.0.0.1:8000"
  },
  "app": {
    "windows": [
      {
        "title": "JamForce GNSS Monitor",
        "width": 1280,
        "height": 800,
        "url": "http://127.0.0.1:8000",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
